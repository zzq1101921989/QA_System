  "bugs": {
    "url": "https://github.com/zzq1101921989/QA_System/issues"
  },
  "homepage": "https://github.com/zzq1101921989/QA_System#readme",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
